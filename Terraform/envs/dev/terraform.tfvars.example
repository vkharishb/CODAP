# Copy this to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored - never commit it.

aws_region   = "ap-south-1"
cluster_name = "codap-dev"
azs          = ["ap-south-1a", "ap-south-1b"]

# Lock this down to your IP (e.g. ["203.0.113.4/32"]) once you're past
# initial testing - do not leave this as 0.0.0.0/0.
admin_cidr_blocks = ["0.0.0.0/0"]

