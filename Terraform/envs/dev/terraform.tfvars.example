aws_region      = "ap-south-1"
cluster_name    = "codap-dev"
cluster_version = "1.35"
azs             = ["ap-south-1a", "ap-south-1b"]

# Replace with your public IP, for example ["203.0.113.10/32"].
admin_cidr_blocks = ["0.0.0.0/0"]

# Optional: IAM role/user ARN for cluster-admin access.
admin_principal_arn = ""

tags = {
  Project     = "CODAP"
  Environment = "dev"
  Owner       = "DevOps"
  ManagedBy   = "Terraform"
}
