{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECRAuthentication",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "DescribeCODAPRepositories",
      "Effect": "Allow",
      "Action": "ecr:DescribeRepositories",
      "Resource": [
        "arn:aws:ecr:ap-south-2:230477418786:repository/codap-demo-app",
        "arn:aws:ecr:ap-south-2:230477418786:repository/codap-dora-metrics-service"
      ]
    },
    {
      "Sid": "PushCODAPImages",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:PutImage"
      ],
      "Resource": [
        "arn:aws:ecr:ap-south-2:230477418786:repository/codap-demo-app",
        "arn:aws:ecr:ap-south-2:230477418786:repository/codap-dora-metrics-service"
      ]
    }
  ]
}
